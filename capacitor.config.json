{
  "appId": "fr.mirella.app",
  "appName": "Mirella",
  "webDir": "www",
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#FF6B6B"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#FF6B6B",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#FF6B6B"
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#FF6B6B",
      "sound": "beep.wav"
    }
  }
}