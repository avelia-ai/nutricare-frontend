{
  "appId": "fr.mirella.app",
  "appName": "Mirella",
  "webDir": "www",
  "server": {
    "url": "https://mirella-ai.fr/app",
    "cleartext": false
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#FF6B6B"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#FF6B6B",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#FF6B6B"
    }
  }
}
